# EditorConfig — KtLint follows this for formatting rules
# https://editorconfig.org / https://pinterest.github.io/ktlint/latest/rules/configuration-ktlintrc/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.{kt,kts}]
# KtLint specific rules
ktlint_code_style = android_studio

# Allow wildcard imports for Compose and common Android packages
ktlint_standard_no-wildcard-imports = disabled

# Compose functions use PascalCase — allow this
ktlint_standard_function-naming = disabled

# Trailing comma — follow Kotlin style
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled

# Allow multi-line function signatures without specific formatting
ktlint_standard_function-signature = disabled

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,xml}]
indent_size = 4

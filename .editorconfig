root = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 140
insert_final_newline = true
trim_trailing_whitespace = true

# Allow PascalCase function names when annotated with @Composable — this is
# the idiomatic Jetpack Compose convention and ktlint supports ignoring the
# function-naming rule for annotated functions.
ktlint_function_naming_ignore_when_annotated_with = Composable,Preview

# The project has historical property names (e.g. TAG-like uppercase) that
# don't match ktlint's default property-naming rule; relax it so the check
# focuses on newer code.
ktlint_standard_property-naming = disabled

# Chained `.get()` calls against the version catalog look worse multi-lined.
ktlint_standard_chain-method-continuation = disabled

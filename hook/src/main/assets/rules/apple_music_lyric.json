{
  "schema": "janus_hook_rule_v1",
  "id": "apple_music_lyric",
  "name": "Apple Music Lyrics",
  "version": 1,
  "author": "penguinyzsh",
  "description": "Extract Apple Music lyrics from TTML parser and inject into MediaSession TITLE for back screen display",
  "targetPackage": "com.apple.android.music",
  "configFlag": "enable_apple_music_lyric",
  "order": 50,
  "engine": "apple_music_lyric",
  "targets": {
    "lyrics_viewmodel": "com.apple.android.music.player.viewmodel.PlayerLyricsViewModel",
    "ttml_parser": "com.apple.android.music.ttml.javanative.TTMLParser$TTMLParserNative"
  }
}
